+module_param(force_clevo_kb_backlight_type, int, 0644);
+MODULE_PARM_DESC(force_clevo_kb_backlight_type,
+	"Override detected Clevo kbd backlight type (-1=auto,1=fixed,2=3zone,6=1zone,243=perkey)");
