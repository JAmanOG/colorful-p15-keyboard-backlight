#!/usr/bin/env python3
"""
kbdlight-listen — map the keyboard's backlight Fn keys to kbdlight.

Reads raw input events from the "TUXEDO Keyboard" device (no external deps) and
runs `kbdlight up|down|toggle` on KEY_KBDILLUMUP / KBDILLUMDOWN / KBDILLUMTOGGLE.
Runs as a root systemd service so it works regardless of desktop environment.
"""
import glob
import os
import struct
import subprocess
import time

# struct input_event (64-bit): timeval (2x long) + type(u16) + code(u16) + value(s32)
EV_FMT = "llHHi"
EV_SIZE = struct.calcsize(EV_FMT)
EV_KEY = 0x01

# evdev key codes -> kbdlight action
KEYMAP = {
    230: "up",       # KEY_KBDILLUMUP     (Fn + +)
    229: "down",     # KEY_KBDILLUMDOWN   (Fn + -)
    228: "toggle",   # KEY_KBDILLUMTOGGLE (Fn + *)
}

KBD = os.environ.get("KBDLIGHT_BIN", "/usr/local/bin/kbdlight")
DEV_NAME = os.environ.get("KBDLIGHT_INPUT_NAME", "TUXEDO Keyboard")


def find_device():
    for name_path in glob.glob("/sys/class/input/event*/device/name"):
        try:
            with open(name_path) as f:
                if f.read().strip() == DEV_NAME:
                    return "/dev/input/" + name_path.split("/")[4]
        except OSError:
            continue
    return None


def run(action):
    try:
        subprocess.Popen([KBD, action],
                         stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except OSError:
        pass


def listen(dev):
    with open(dev, "rb") as f:
        while True:
            data = f.read(EV_SIZE)
            if not data or len(data) < EV_SIZE:
                return
            _, _, etype, code, value = struct.unpack(EV_FMT, data)
            if etype == EV_KEY and value == 1 and code in KEYMAP:   # key-down only
                run(KEYMAP[code])


def main():
    while True:
        dev = find_device()
        if dev:
            try:
                listen(dev)
            except OSError:
                pass
        time.sleep(2)   # device missing or driver reloaded -> rescan


if __name__ == "__main__":
    main()
